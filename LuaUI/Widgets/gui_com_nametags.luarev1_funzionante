local function DrawName(unitID, attributes)
    if not attributes then return end

    -- CORREZIONE: Passiamo gli argomenti separati come richiesto dalla funzione
    if comnameList[attributes.name] == nil then
        comnameList[attributes.name] = createComnameList(attributes.name, attributes.color)
    end

    glTranslate(0, attributes.height, 0)
    glBillboard()

    if nameScaling then
        local ratio = usedFontSize / fontSize
        glScale(ratio, ratio, ratio)
    end

    -- 1. DISEGNA IL NOME (Centrato in 0,0)
    glCallList(comnameList[attributes.name])

    -- 2. DISEGNA LE ICONE (A sinistra del nome, sulla stessa riga)
    gl.Color(1, 1, 1, 1) -- Reset colore per le texture

    local iconSize = 18    -- Dimensione delle icone
    local iconY = 0        -- Allineamento verticale (0 è la base del testo)
    local padding = 5      -- Spazio tra le icone
    
    -- Calcoliamo la posizione X per andare a sinistra del nome centrato.
    -- Poiché il nome è centrato, lo zero è il centro. 
    -- Ci spostiamo a sinistra di un valore fisso.
    local startX = -45 

    -- BANDIERA (Posizionata più vicina al nome)
    if attributes.country then
        gl.Texture(flagsDirectory .. tostring(attributes.country) .. ".png")
        -- X da -40 a -15 (larghezza 25)
        gl.TexRect(startX + 5, iconY, startX + 30, iconY + iconSize)
        gl.Texture(false)
    end
    
    -- AVATAR (Posizionato a sinistra della bandiera)
    if attributes.avatar then
        gl.Texture(avatarDirectory .. tostring(attributes.avatar) .. ".png")
        -- X da -65 a -45 (larghezza 20)
        gl.TexRect(startX - 20, iconY, startX, iconY + iconSize)
        gl.Texture(false)
    end

    if nameScaling then
        glScale(1, 1, 1)
    end
end


function widget:DrawWorld()
    glDepthTest(true)
    glAlphaTest(GL_GREATER, 0)
    glBlending(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA)
   
    local camX, camY, camZ = GetCameraPosition()
    
    for unitID, attributes in pairs(comms) do
        if IsUnitInView(unitID) then
            local x, y, z = GetUnitPosition(unitID)
            local camDistance = diag(camX-x, camY-y, camZ-z) 
            usedFontSize = (fontSize * 0.5) + (camDistance / scaleFontAmount)
            
            glDrawFuncAtUnit(unitID, false, DrawName, unitID, attributes)
        end
    end
    
    glAlphaTest(false)
    glColor(1, 1, 1, 1)
end

function CheckCom(unitID, unitDefID)
  -- Se unitDefID non è passato (come in UnitEnteredLos), lo prendiamo noi
  if not unitDefID then
    unitDefID = Spring.GetUnitDefID(unitID)
  end

  -- 1. Controllo che unitDefID sia valido
  -- 2. Controllo che UnitDefs[unitDefID] esista effettivamente
  if unitDefID and UnitDefs[unitDefID] then
    local ud = UnitDefs[unitDefID]
    
    -- Usiamo customParams (P maiuscola) perché è lo standard Lua di Spring
    -- Aggiungiamo un controllo per evitare errori se customParams fosse vuoto
    if ud.customParams and ud.customParams.iscommander then
      comms[unitID] = GetCommAttributes(unitID, unitDefID)
    end
  end
end


function CheckAllComs()
    local allUnits = GetAllUnits()
    for _, unitID in pairs(allUnits) do
        CheckCom(unitID, GetUnitDefID(unitID))
    end
end

function widget:Initialize()
    CheckAllComs()
end

function widget:UnitCreated(unitID, unitDefID, unitTeam)
  CheckCom(unitID, unitDefID)
end
function widget:UnitDestroyed(unitID) comms[unitID] = nil end
function widget:UnitGiven(unitID, unitDefID, unitTeam, oldTeam)
  CheckCom(unitID, unitDefID)
end
function widget:UnitEnteredLos(unitID, allyTeam)
  CheckCom(unitID) -- Passiamo solo unitID, CheckCom si troverà il DefID da solo
end
function widget:UnitTaken(unitID, unitDefID, unitTeam, newTeam)
  CheckCom(unitID, unitDefID)
end
function widget:PlayerChanged(playerID)
    CheckAllComs() -- rinfresca se un giocatore cambia nome o diventa spectator
end