-- Recupera gli attributi (Nome, Colore, Avatar, Country)
local function GetCommAttributes(unitID, unitDefID)
    local team = GetUnitTeam(unitID)
    if team == nil then return nil end
    
    local players = GetPlayerList(team)
    local name = 'AI'
    local country = nil
    local rank = nil
    local avatar = nil

    if players and #players > 0 then
        for _, pID in ipairs(players) do
            local pname, active, _, _, _, _, _, pcountry, prank = GetPlayerInfo(pID)
            if active then
                name = pname
                country = pcountry
                rank = prank
                -- Ottimizzazione Avatar: legge dinamicamente dalle ModOptions
                local modOpts = Spring.GetModOptions()
                avatar = modOpts["avatar" .. pID]
                break
            end
        end
    end

    local r, g, b, a = GetTeamColor(team)
    local height = UnitDefs[unitDefID].height + heightOffset
    
    return {
        name = name, 
        color = {r, g, b, a}, 
        height = height, 
        avatar = avatar, 
        country = country, 
        rank = rank
    }
end

local function createComnameList(name, color)
    return gl.CreateList(function()
        local r, g, b, a = unpack(color)
        local outlineColor = {0,0,0,1}
        if (r + g*1.35 + b*0.5) < 0.8 then
            outlineColor = {1,1,1,1}
        end

        if useThickLeterring then
            -- Disegna l'ombra/contorno spesso
            font:SetTextColor(outlineColor)
            font:Print(name, -(fontSize/38), -(fontSize/33), fontSize, "con")
            font:Print(name, (fontSize/38), -(fontSize/33), fontSize, "con")
        end
        
        -- Disegna il testo principale
        font:Begin()
        font:SetTextColor(color)
        font:SetOutlineColor(outlineColor)
        font:Print(name, 0, 0, fontSize, "con")
        font:End()
    end)
end
