}

RockUnit(anglex, anglez)
{
	turn rockpt to x-axis (anglex * 2) speed <90.000000>;
	turn rockpt to z-axis (anglez * 2) speed <90.000000>;
	wait-for-turn rockpt around z-axis;
	wait-for-turn rockpt around x-axis;
	turn rockpt to z-axis <0.000000> speed <20.000000>;
	turn rockpt to x-axis <0.000000> speed <20.000000>;
	return(0);
}
	
HitByWeapon(anglex, anglez)
{
	OldHealth_7 = Health_6;
	Health_6 = get HEALTH;	
	if(( OldHealth_7 - Health_6 ) >= 4 )
	{
		if((( Health_6 <= 50 ) AND ( Health_6 > 20 ))  AND Arm2 )
		{
			Arm2 = 0;
			return(0);
		}
		if(( Health_6 <= 20 ) AND Arm1 )
		{
			Arm1 = 0;
			return(0);
		}
	}
	return(0);
}	

Create()
{
	hide Flare;
	dont-cache Flare;
	dont-shade Flare;
	dont-cache light;
	dont-shade light;
	spin flare around y-axis speed <500>;
	bMoving = FALSE;
	bAiming = FALSE;
	CanAim_3 = 1;
	walkin = 0;
	Holstered_5 = 1;
	Arm2 = 1;
	Arm1 = 1;
	Armdead2 = 0;
	Armdead1 = 0;
	hide BFG;
	hide light;
	while( get BUILD_PERCENT_LEFT )
	{
		sleep 400;
	}
	Health_6 = get HEALTH;
	start-script SmokeUnit();
	start-script ArmExplode();
	return(0);
}

StartMoving()
{
	bMoving = TRUE;
	if( !walkin )
	{
		start-script Walk();
	}
	return(0);
}

StopMoving()
{
	bMoving = FALSE;
	return(0);
}

RestoreAfterDelay()
{	
	sleep 10000;
	dont-cache light;
	turn Torso to y-axis <0> speed <120>;
	turn Torso to x-axis <0> speed <80>;
	turn upArm1 to x-axis <0> speed <120>;
	turn MidArm1 to z-axis <0> speed <20>;
	turn LowArm1 to y-axis <0> speed <30>;
	sleep 500;
	if( !Holstered_5 AND Arm1 )
	{
		set-signal-mask 2;
		turn Midarm1 to z-axis <-30> speed <160>;
		turn Midarm2 to z-axis <0> speed <60>;
		turn Midarm2 to y-axis <0> speed <150>;
		turn UpArm2 to x-axis <-50> speed <120>;
		if( !Arm2 )
		{
			sleep 500;
		}
		turn UpArm1 to x-axis <-160> speed <300>;
		turn Lowarm1 to x-axis <-90> speed <200>;
		turn Midarm1 to y-axis <0> speed <150>;
		wait-for-turn UpArm1 around x-axis;
		wait-for-turn Lowarm1 around x-axis;
		hide BFG;
		hide light;
	 	show backgun;
		Holstered_5 = TRUE;
		turn BFG to z-axis <0> speed <150>;
		turn Midarm2 to z-axis <0> speed <60>;
		turn Lowarm2 to z-axis <0> speed <160>;
		turn Lowarm2 to y-axis <0> speed <160>;
		turn Midarm1 to y-axis <0> speed <40.005495>;
		turn Lowarm1 to z-axis <0> speed <160>;
		turn Lowarm1 to x-axis <0> speed <60>;
		if( !Arm2 )
		{
			sleep 500;
		}
		turn UpArm1 to x-axis <0> speed <150>;
		turn Lowarm2 to x-axis <0> speed <150>;
		turn UpArm2 to x-axis <0> speed <120>;
		turn Midarm1 to z-axis <0> speed <150>;
		turn Midarm2 to x-axis <0> speed <150>;
		turn Lowarm2 to x-axis <0> speed <75>;
		turn Midarm2 to y-axis <0> speed <150>;
		turn Midarm1 to x-axis <0> speed <150>;
	}
	bAiming = 0;
	Return(0);
}

SweetSpot(piecenum)
{
	piecenum = Torso;
}

QueryPrimary(piecenum)
{
	piecenum = Flare;
}

AimFromPrimary(piecenum)
{
	piecenum = UpArm1;
}

AimPrimary(heading, pitch)
{
	bAiming = TRUE;
	signal 2;
	set-signal-mask 2;
	while( !CanAim_3 )
	{
		sleep 200;
	}
	if( Arm1 )
	{
		if( Holstered_5 )
		{
			turn Lowarm2 to z-axis <20> speed <80>;
			turn Lowarm2 to z-axis <30> speed <75>;
			turn Lowarm2 to x-axis <0> speed <75>;
			turn Lowarm2 to y-axis <45> speed <75>;
			turn Midarm2 to z-axis <40> speed <80>;
			turn UpArm2 to x-axis <-50> speed <120>;
			turn UpArm1 to x-axis <-160> speed <300>;
			if( !Arm2 )
			{
				sleep 750;
			}
			turn Lowarm1 to x-axis <-90> speed <200>;
			wait-for-turn UpArm1 around x-axis;
			wait-for-turn Lowarm1 around x-axis;
			show BFG;
			show light;
			hide backgun;
			Holstered_5 = FALSE;
			//sleep 1000;
		}
		turn Lowarm1 to x-axis <0> speed <200>;
		turn UpArm2 to x-axis <-50> speed <120>;
		if( !Arm2 )
		{
			sleep 750;
		}
		turn MidArm1 to z-axis <-30> speed <30>;
		turn UpArm1 to x-axis <-90> speed <180>;
		wait-for-turn UpArm2 around x-axis;
		wait-for-turn Lowarm2 around z-axis;
		wait-for-turn Lowarm1 around x-axis;
		wait-for-turn UpArm1 around x-axis;
	}
	turn LowArm1 to y-axis <15> speed <30>;
	if( Arm2 )
	{
		turn Torso to y-axis (heading - <30>) speed <150>;
		turn Torso to x-axis <0> - pitch speed <100>;
	}
	if( !Arm2 )
	{
		turn Torso to y-axis (heading - <30>) speed <90>;
		turn Torso to x-axis <0> - pitch speed <75>;
	}
	wait-for-turn LowArm1 around y-axis;
	wait-for-turn Torso around y-axis;
	wait-for-turn Torso around x-axis;
	start-script RestoreAfterDelay();
	while( !Arm1 )
	{
		sleep 2000;
	}
	return (1);
}

FirePrimary()
{
	cache light;
	show flare;
	sleep 150;
	turn LowArm1 to x-axis <-45> speed <180>;
	turn UpArm2 to z-axis <-30> speed <90>;
	turn UpArm2 to x-axis <-80> speed <90>;
	hide flare;
	sleep 500;
	turn UpArm2 to z-axis <0> speed <30>;
	turn UpArm2 to x-axis <-30> speed <40>;	
	turn LowArm1 to x-axis <0> speed <45>;
	sleep 1500;
	dont-cache light;
	return(0);
}

Killed(severity, corpsetype)
{
	hide Flare;
	if( !armdead1 and !armdead2 )
	{
		if( severity <= 25 )
		{
			corpsetype = 1;
			explode Pelvis type BITMAPONLY | BITMAP3;
			explode Upleg1 type BITMAPONLY | BITMAP1;
			explode Foot1 type BITMAPONLY | BITMAP1;
			explode Upleg2 type BITMAPONLY | BITMAP1;
			explode Foot2 type BITMAPONLY | BITMAP1;
			explode Torso type BITMAPONLY | BITMAP1;
			explode MidArm1 type BITMAPONLY | BITMAP1;
			explode LowArm1 type BITMAPONLY | BITMAP1;
			explode MidArm2 type BITMAPONLY | BITMAP1;
			explode LowArm2 type BITMAPONLY | BITMAP1;
			if( !Holstered_5 AND Arm1 )
			{
				explode BFG type FALL | FIRE | EXPLODE_ON_HIT | BITMAP4;
				explode light type FALL | FIRE | EXPLODE_ON_HIT | BITMAP3;
				return (0);
			}
			explode backgun type FALL | FIRE | EXPLODE_ON_HIT | BITMAP4;
			return (0);
		}
	}
	if( severity <= 50 )
	{
		corpsetype = 2;
		explode Pelvis type FALL | BITMAP5;
		explode Upleg1 type FALL | BITMAP1;
		explode Foot1 type BITMAPONLY | BITMAP4;
		explode Upleg2 type FALL | BITMAP1;
		explode Foot2 type BITMAPONLY | BITMAP4;
		explode Torso type BITMAPONLY | BITMAP3;
		if( !Armdead2 )
		{
			explode UpArm2 type FALL | FIRE | BITMAP3;
			explode LowArm2 type SHATTER | BITMAP4;
		}
		if( !Armdead1 )
		{
			explode UpArm1 type FALL | FIRE | BITMAP4;
			explode MidArm1 type FALL | BITMAP4;
			explode LowArm1 type FALL | BITMAP4;
			if( !Holstered_5 AND Arm1 )
			{
				explode BFG type FALL | FIRE | EXPLODE_ON_HIT | BITMAP4;
				explode light type FALL | FIRE | EXPLODE_ON_HIT | BITMAP3;
				return (0);
			}
			explode backgun type FALL | FIRE | EXPLODE_ON_HIT | BITMAP4;
		}
		return (0);
	}
	if( severity <= 99 )
	{
		corpsetype = 3;
		explode Pelvis type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP3;
		explode Upleg1 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode Foot1 type SHATTER | EXPLODE_ON_HIT | BITMAP4;
		explode Upleg2 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
		explode Foot2 type SHATTER | EXPLODE_ON_HIT | BITMAP4;
		explode Torso type BITMAPONLY | BITMAP2;
		if( !Armdead2 )
		{
			explode UpArm2 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP3;
			explode MidArm2 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP5;
			explode LowArm2 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP2;
		}
		if( !Armdead1 )
		{		
			explode UpArm1 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP3;
			explode MidArm1 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP5;
			explode LowArm1 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP2;
			if( !Holstered_5 AND Arm1 )
			{
				explode BFG type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP2;
				explode light type FALL | FIRE | EXPLODE_ON_HIT | BITMAP3;
				return(0);
			}
			explode backgun type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP2;
		}
		return (0);
	}
	corpsetype = 3;
	explode Pelvis type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP3;
	explode Upleg1 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
	explode Foot1 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP4;
	explode Lowleg1 type SHATTER | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP2;
	explode Upleg2 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP1;
	explode Foot2 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP4;
	explode LowLeg2 type SHATTER | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP2;
	explode Torso type BITMAPONLY | BITMAP2;
	if( !Armdead2 )
	{
		explode UpArm2 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP3;
		explode MidArm2 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP5;
		explode LowArm2 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP2;
	}
	if( !Armdead1 )
	{
		explode UpArm1 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP4;
		explode MidArm1 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP5;
		explode LowArm1 type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP2;
		if( !Holstered_5 AND Arm1 )
		{
			explode BFG type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP2;
			explode light type FALL | FIRE | EXPLODE_ON_HIT | BITMAP3;
			Return(0);
		}
		explode backgun type FALL | SMOKE | FIRE | EXPLODE_ON_HIT | BITMAP2;
	}
}
