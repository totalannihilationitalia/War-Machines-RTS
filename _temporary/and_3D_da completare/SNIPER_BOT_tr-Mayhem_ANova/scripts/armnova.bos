#define TA			// This is a TA script

#include "sfxtype.h"
#include "exptype.h"

piece  Pelvis, UpArm1, UpArm2, Torso, Upleg1, Lowleg1, Upleg2, Lowleg2, 
       Foot1, Foot2, MidArm1, LowArm1, Flare, MidArm2, LowArm2,
       BFG, light, backgun, Finger1a, Finger1b, Finger2a, Finger2b, rockpt;

static-var  bMoving, bAiming, CanAim_3, walkin, Holstered_5, health_6, oldhealth_7, arm2,
            arm1, armdead1, armdead2;


SmokeUnit(healthpercent, sleeptime, smoketype)
{
	var randpiece;
	while( TRUE )
	{
		healthpercent = get HEALTH;
		if( !Arm1 )
		{
			if( healthpercent >= 65 )
			{
				show UpArm1;
				show MidArm1;
			}
			if( healthpercent >= 70 )
			{
				show LowArm1;
				show Finger1a;
				show Finger1b;
				Armdead1 = 0;
				if( Holstered_5 )
				{
					Arm1 = 1;
				}					
			}
			if( healthpercent >= 75 )
			{
				show backgun;
				Holstered_5 = 1;
				Arm1 = 1;
			}
		}
		if( !Arm2 )
		{
			if( healthpercent >= 80 )
			{
				show UpArm2;
				show MidArm2;
			}
			if( healthpercent >= 85 )
			{
				show LowArm2;
				Armdead2 = 0;
			}
			if( healthpercent >= 90 )
			{
				Arm2 = 1;
				show Finger2a;
				show Finger2b;
			}
		}				
		if( healthpercent < 66 )
		{
			smoketype = 256 | 2;
			randpiece = rand( 0, 3 );
			if( Rand( 1, 66 ) < healthpercent )
			{
				smoketype = 256 | 1;
			}
			if( !randpiece )
			{
				emit-sfx smoketype from pelvis;
			}
			if( randpiece == 1 )
			{
				emit-sfx smoketype from uparm1;
			}
			if( randpiece == 2 )
			{
				emit-sfx smoketype from uparm2;
			}
			if( randpiece == 3 )
			{
				emit-sfx smoketype from torso;
			}
		}
		sleeptime = healthpercent * 50;
		if( sleeptime < 200 )
		{
			sleeptime = 200;
		}
		sleep sleeptime;
	}
}

ArmExplode()
{
	while( TRUE )
	{
		if( !arm1 and !armdead1 )
		{
			armdead1 = 1;
			bAiming = 1;
			hide BFG;
			hide light;
			hide MidArm1;
			hide UpArm1;
			hide LowArm1;
			hide Finger1a;
			hide Finger1b;
			if( !Holstered_5 )
			{
				hide backgun;
				explode BFG type FALL | FIRE | EXPLODE_ON_HIT | BITMAP3;
				explode light type FALL | FIRE | EXPLODE_ON_HIT | BITMAP3;
			}
			explode UpArm1 type FALL | FIRE | EXPLODE_ON_HIT | BITMAP3;
			explode MidArm1 type FALL | FIRE | BITMAP4;
			explode LowArm1 type FALL | FIRE | EXPLODE_ON_HIT | BITMAP4;
			explode Finger1a type FALL | FIRE | BITMAP4;
			explode Finger1b type SHATTER | FIRE | BITMAP4;
			signal 2;
			sleep 1000;
			bAiming = 0;
		}
		if( !arm2 and !armdead2 )
		{
			armdead2 = 1;
			hide MidArm2;
			hide LowArm2;
			hide Finger2a;
			hide Finger2b;
			explode UpArm2 type FALL | FIRE | EXPLODE_ON_HIT | BITMAP3;
			explode MidArm2 type FALL | BITMAP4;
			explode LowArm2 type FALL | BITMAP4;
			explode Finger2a type FALL | BITMAP4;
			explode Finger2b type SHATTER | FIRE | BITMAP4;
		}
		sleep 200;
	}
	return(0);
}

